# -------------------------
# API ENDPOINTS
# -------------------------
NEXT_PUBLIC_API_URL_DEV=http://localhost:5000/api/v1
NEXT_PUBLIC_API_URL_PROD=

# -------------------------
# SOCKET.IO (same host as API, without /api/v1)
# -------------------------
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# -------------------------
# FULL INTERACTIVE DEMO (hosted preview, no backend)
# -------------------------
# When true, all REST/GraphQL use in-browser mocks (auth, cart, checkout, admin).
# Set this on Vercel for the public demo deployment.
# NEXT_PUBLIC_DEMO_MODE=true

# -------------------------
# DEMO CATALOG ONLY (legacy / partial)
# -------------------------
# When true, always use static sample products/categories (cart/auth still need API unless DEMO_MODE is on).
# When false/unset, the client falls back to demo catalog data if the API is unreachable.
# NEXT_PUBLIC_USE_DEMO_CATALOG=true

# -------------------------
# ENVIRONMENT
# -------------------------
NODE_ENV=development
