# -------------------------
# API ENDPOINTS
# -------------------------
NEXT_PUBLIC_API_URL_DEV=http://localhost:5000/api/v1
NEXT_PUBLIC_API_URL_PROD=

# -------------------------
# SOCKET.IO (same host as API, without /api/v1)
# -------------------------
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# -------------------------
# DEMO CATALOG (browse-only, no API)
# -------------------------
# When true, always use static sample products/categories (cart/auth still need API).
# When false/unset, the client falls back to demo data automatically if the API is unreachable.
# NEXT_PUBLIC_USE_DEMO_CATALOG=true

# -------------------------
# ENVIRONMENT
# -------------------------
NODE_ENV=development
